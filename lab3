def la_nam_nhuan(nam):
    if nam % 400 == 0:
        return True
    elif nam % 100 == 0:
        return False
    elif nam % 4 == 0:
        return True
    else:
        return False
# chạy chương trình 
nam = int(input("Nhập số năm:"))
if la_nam_nhuan(nam):
    print(nam, "là năm nhuận ")
else:
    print(nam, "không phải là nhăm nhuận")
